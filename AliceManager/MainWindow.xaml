<mah:MetroWindow x:Class="AliceManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        xmlns:materialDesign="http://materialdesigninxaml.net/winfx/xaml/themes"
        xmlns:tb="http://www.hardcodet.net/taskbar"
        Title="Alice Manager"
        Width="1150" Height="650"
        MinWidth="850" MinHeight="500"
        WindowStartupLocation="CenterScreen"
        TitleCharacterCasing="Normal"
        ShowIconOnTitleBar="False"
        SaveWindowPosition="True"
        BorderThickness="0.5"
        BorderBrush="Black"
        TitleBarHeight="30"
        IsWindowDraggable="True"
        Loaded="Window_Loaded">

    <mah:MetroWindow.LeftWindowCommands>
        <mah:WindowCommands>
            <Button IsHitTestVisible="False">
                <StackPanel Orientation="Horizontal">
                    <Ellipse Width="8" Height="8" Margin="0,0,6,0">
                        <Ellipse.Fill>
                            <SolidColorBrush Color="#F44336" x:Name="StatusDotColor"/>
                        </Ellipse.Fill>
                    </Ellipse>
                    <TextBlock FontSize="11" Text="Disconnected" x:Name="StatusText"/>
                </StackPanel>
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.LeftWindowCommands>

    <mah:MetroWindow.RightWindowCommands>
        <mah:WindowCommands>
            <Button Cursor="Hand" Click="NavButton_Click" Tag="0">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="ViewDashboard" Width="14" Height="14"/>
                    <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" Text="Dashboard"/>
                </StackPanel>
            </Button>
            <Button Cursor="Hand" Click="NavButton_Click" Tag="1">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Package" Width="14" Height="14"/>
                    <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" Text="Mods"/>
                </StackPanel>
            </Button>
            <Button Cursor="Hand" Click="NavButton_Click" Tag="2">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Console" Width="14" Height="14"/>
                    <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" Text="Logs"/>
                </StackPanel>
            </Button>
            <Button Cursor="Hand" Click="NavButton_Click" Tag="3">
                <StackPanel Orientation="Horizontal">
                    <materialDesign:PackIcon Kind="Cog" Width="14" Height="14"/>
                    <TextBlock Margin="4,0,0,0" VerticalAlignment="Center" Text="Settings"/>
                </StackPanel>
            </Button>
        </mah:WindowCommands>
    </mah:MetroWindow.RightWindowCommands>

    <Grid>
        <!-- 系统托盘 -->
        <tb:TaskbarIcon x:Name="TrayIcon" Visibility="Visible" ToolTipText="Alice Manager"
                        TrayMouseDoubleClick="TrayIcon_DoubleClick">
            <tb:TaskbarIcon.ContextMenu>
                <ContextMenu>
                    <MenuItem Header="Show" Click="TrayMenu_Show"/>
                    <MenuItem Header="Hide" Click="TrayMenu_Hide"/>
                    <Separator/>
                    <MenuItem Header="Restart Server" Click="TrayMenu_RestartServer"/>
                    <Separator/>
                    <MenuItem Header="Exit" Click="TrayMenu_Exit"/>
                </ContextMenu>
            </tb:TaskbarIcon.ContextMenu>
        </tb:TaskbarIcon>

        <!-- 主内容 -->
        <TabControl Margin="0" x:Name="MainTab" BorderThickness="0">
            <TabControl.ItemContainerStyle>
                <Style TargetType="TabItem">
                    <Setter Property="Visibility" Value="Collapsed"/>
                </Style>
            </TabControl.ItemContainerStyle>

            <!-- ═══ Tab 0: Dashboard ═══ -->
            <TabItem>
                <ScrollViewer Background="#FFE5E5E5" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                    <StackPanel Margin="20,16,20,20">

                        <!-- 状态卡片行 (自适应换行) -->
                        <UniformGrid Rows="1" Margin="0,0,0,16" x:Name="DashCards">
                            <!-- Server -->
                            <Border Background="White" CornerRadius="4" Padding="18,14" Margin="0,0,8,0"
                                    BorderBrush="#E0E0E0" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Text="SERVER" FontSize="10" Foreground="#999" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                        <TextBlock Text="Offline" FontSize="20" FontWeight="Bold" Foreground="#F44336"
                                                   x:Name="DashServerStatus"/>
                                        <TextBlock FontSize="10" Foreground="#BBB" Margin="0,4,0,0"
                                                   x:Name="DashServerAddr" Text="localhost:645"/>
                                    </StackPanel>
                                    <Ellipse Grid.Column="1" Width="12" Height="12" VerticalAlignment="Top" Margin="0,2,0,0"
                                             x:Name="DashServerDot" Fill="#F44336"/>
                                </Grid>
                            </Border>

                            <!-- Mods -->
                            <Border Background="White" CornerRadius="4" Padding="18,14" Margin="4,0,4,0"
                                    BorderBrush="#E0E0E0" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="MODS" FontSize="10" Foreground="#999" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="0" FontSize="20" FontWeight="Bold" x:Name="DashModCount"/>
                                        <TextBlock Text=" loaded" FontSize="12" Foreground="#999" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                                    </StackPanel>
                                    <TextBlock Text="0 from source" FontSize="10" Foreground="#BBB" Margin="0,4,0,0"
                                               x:Name="DashModSrcCount"/>
                                </StackPanel>
                            </Border>

                            <!-- Services -->
                            <Border Background="White" CornerRadius="4" Padding="18,14" Margin="4,0,4,0"
                                    BorderBrush="#E0E0E0" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="SERVICES" FontSize="10" Foreground="#999" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="0" FontSize="20" FontWeight="Bold" x:Name="DashServiceCount"/>
                                        <TextBlock Text=" registered" FontSize="12" Foreground="#999" VerticalAlignment="Bottom" Margin="0,0,0,3"/>
                                    </StackPanel>
                                </StackPanel>
                            </Border>

                            <!-- Uptime -->
                            <Border Background="White" CornerRadius="4" Padding="18,14" Margin="8,0,0,0"
                                    BorderBrush="#E0E0E0" BorderThickness="1">
                                <StackPanel>
                                    <TextBlock Text="UPTIME" FontSize="10" Foreground="#999" FontWeight="SemiBold" Margin="0,0,0,6"/>
                                    <TextBlock Text="--:--:--" FontSize="20" FontWeight="Bold" x:Name="DashUptime"/>
                                </StackPanel>
                            </Border>
                        </UniformGrid>

                        <!-- Quick Actions -->
                        <TextBlock Text="Quick Actions" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,10"/>
                        <WrapPanel Margin="0,0,0,16">
                            <Button Height="28" Margin="0,0,6,6" Padding="12,0" Click="OpenModsFolder_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Open Mods Folder"/>
                                </StackPanel>
                            </Button>
                            <Button Height="28" Margin="0,0,6,6" Padding="12,0" Click="DashInstall_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Install Mod"/>
                                </StackPanel>
                            </Button>
                            <Button Height="28" Margin="0,0,6,6" Padding="12,0" Click="DashOpenConfig_Click">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe MDL2 Assets" FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Open Config"/>
                                </StackPanel>
                            </Button>
                        </WrapPanel>

                        <!-- Loaded Mods 列表 -->
                        <TextBlock Text="Loaded Mods" FontSize="13" FontWeight="SemiBold" Margin="0,0,0,8"/>
                        <ItemsControl x:Name="DashModList">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border Background="White" CornerRadius="3" Padding="12,8" Margin="0,0,0,4"
                                            BorderBrush="#E8E8E8" BorderThickness="1">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <StackPanel Grid.Column="0" Orientation="Horizontal">
                                                <TextBlock Text="{Binding Name}" FontWeight="SemiBold" VerticalAlignment="Center"/>
                                                <TextBlock Text="{Binding Version}" FontSize="10" Foreground="#AAA"
                                                           Margin="8,0,0,0" VerticalAlignment="Center"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="1" Text="{Binding Runtime}" FontSize="10"
                                                       Foreground="#888" VerticalAlignment="Center" Margin="0,0,12,0"/>
                                            <TextBlock Grid.Column="2" Text="{Binding StatusText}" FontSize="10"
                                                       VerticalAlignment="Center">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#999"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding Status}" Value="Loaded">
                                                                <Setter Property="Foreground" Value="#4CAF50"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Grid>
                                    </Border>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                    </StackPanel>
                </ScrollViewer>
            </TabItem>

            <!-- ═══ Tab 1: Mods ═══ -->
            <TabItem>
                <Grid Background="#FFE5E5E5" Margin="0,2,0,-2">
                    <DataGrid x:Name="ModsGrid"
                              Margin="12,44,12,44"
                              CanUserAddRows="False"
                              AutoGenerateColumns="False"
                              SelectionMode="Single"
                              SelectionUnit="FullRow"
                              HeadersVisibility="Column"
                              CanUserResizeColumns="True"
                              CanUserSortColumns="True"
                              CurrentCellChanged="ModsGrid_CurrentCellChanged"
                              >
                        <DataGrid.Columns>
                            <DataGridCheckBoxColumn Width="50" Header=""
                                                    Binding="{Binding Enabled, UpdateSourceTrigger=PropertyChanged}"/>
                            <DataGridTextColumn Header="Name" Width="220"
                                                Binding="{Binding Name}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Type" Width="90"
                                                Binding="{Binding Type}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Runtime" Width="90"
                                                Binding="{Binding Runtime}" IsReadOnly="True"/>
                            <DataGridTextColumn Header="Version" Width="120"
                                                Binding="{Binding Version}" IsReadOnly="True"/>
                            <DataGridTemplateColumn Header="Status" Width="100" IsReadOnly="True">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding StatusText}" Padding="4,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Loaded">
                                                            <Setter Property="Foreground" Value="#4CAF50"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Disabled">
                                                            <Setter Property="Foreground" Value="#9E9E9E"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="CompileError">
                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                            <Setter Property="FontWeight" Value="SemiBold"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="NotCompiled">
                                                            <Setter Property="Foreground" Value="#FF9800"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Location" Width="*"
                                                Binding="{Binding Location}" IsReadOnly="True"/>
                        </DataGrid.Columns>
                        <DataGrid.ContextMenu>
                            <ContextMenu>
                                <MenuItem Header="Reload" Click="MenuReload_Click">
                                    <MenuItem.Icon><materialDesign:PackIcon Kind="Refresh" Width="14" Height="14"/></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Compile" Click="MenuCompile_Click">
                                    <MenuItem.Icon><materialDesign:PackIcon Kind="Hammer" Width="14" Height="14"/></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Update" Click="MenuUpdate_Click">
                                    <MenuItem.Icon><materialDesign:PackIcon Kind="Download" Width="14" Height="14"/></MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Open Source Folder" Click="MenuOpenSource_Click">
                                    <MenuItem.Icon><materialDesign:PackIcon Kind="FolderEdit" Width="14" Height="14"/></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="Open Runtime Folder" Click="MenuOpenRuntime_Click">
                                    <MenuItem.Icon><materialDesign:PackIcon Kind="Folder" Width="14" Height="14"/></MenuItem.Icon>
                                </MenuItem>
                                <MenuItem Header="GitHub" Click="MenuGithub_Click">
                                    <MenuItem.Icon><materialDesign:PackIcon Kind="Github" Width="14" Height="14"/></MenuItem.Icon>
                                </MenuItem>
                                <Separator/>
                                <MenuItem Header="Remove" Click="MenuRemove_Click" Foreground="#D32F2F">
                                    <MenuItem.Icon><materialDesign:PackIcon Kind="Delete" Width="14" Height="14" Foreground="#D32F2F"/></MenuItem.Icon>
                                </MenuItem>
                            </ContextMenu>
                        </DataGrid.ContextMenu>
                    </DataGrid>

                    <TextBox x:Name="SearchTextBox" Height="26" Width="280"
                             HorizontalAlignment="Right" VerticalAlignment="Top"
                             Margin="0,12,12,0"
                             mah:TextBoxHelper.Watermark="Search mods..."
                             TextChanged="SearchTextBox_TextChanged"/>

                    <Button Content="Update All" HorizontalAlignment="Left"
                            Margin="12,0,0,12" Width="115" Height="28" VerticalAlignment="Bottom"
                            Click="UpdateAll_Click"/>
                    <Button Content="Compile All" HorizontalAlignment="Left"
                            Margin="133,0,0,12" Width="115" Height="28" VerticalAlignment="Bottom"
                            Click="CompileAll_Click"/>

                    <Button Content="Install from GitHub" HorizontalAlignment="Right"
                            Margin="0,0,12,12" Width="190" Height="28" VerticalAlignment="Bottom"
                            Click="InstallButton_Click"/>

                    <mah:ProgressRing IsActive="False" HorizontalAlignment="Right"
                                      Margin="0,0,24,54" VerticalAlignment="Bottom"
                                      Width="48" Height="48"
                                      x:Name="ProgressIndicator"/>
                </Grid>
            </TabItem>

            <!-- ═══ Tab 2: Logs (带颜色 + 自动滚动) ═══ -->
            <TabItem>
                <Grid Background="#FFE5E5E5">
                    <DataGrid x:Name="LogGrid"
                              Margin="10,10,10,40"
                              CanUserAddRows="False"
                              AutoGenerateColumns="False"
                              IsReadOnly="True"
                              HeadersVisibility="Column">
                        <DataGrid.Columns>
                            <DataGridTextColumn Header="Time" Width="85"
                                                Binding="{Binding Time}"/>
                            <DataGridTemplateColumn Header="Level" Width="65">
                                <DataGridTemplateColumn.CellTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding Level}" Padding="2,0">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Level}" Value="error">
                                                            <Setter Property="Foreground" Value="#F44336"/>
                                                            <Setter Property="FontWeight" Value="Bold"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="warning">
                                                            <Setter Property="Foreground" Value="#FF9800"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Level}" Value="debug">
                                                            <Setter Property="Foreground" Value="#9E9E9E"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </DataGridTemplateColumn.CellTemplate>
                            </DataGridTemplateColumn>
                            <DataGridTextColumn Header="Source" Width="150"
                                                Binding="{Binding Source}"/>
                            <DataGridTextColumn Header="Plugin" Width="130"
                                                Binding="{Binding Plugin}"/>
                            <DataGridTextColumn Header="Message" Width="*"
                                                Binding="{Binding Message}"/>
                        </DataGrid.Columns>
                    </DataGrid>

                    <CheckBox x:Name="ChkAutoScroll" Content="Auto-scroll" IsChecked="True"
                              HorizontalAlignment="Right" VerticalAlignment="Bottom"
                              Margin="0,0,12,12"/>

                    <Button Content="Clear Log" HorizontalAlignment="Left"
                            Margin="10,0,0,10" Width="95" Height="25" VerticalAlignment="Bottom"
                            Click="ClearLog_Click"/>
                </Grid>
            </TabItem>

            <!-- ═══ Tab 3: Settings ═══ -->
            <TabItem>
                <Grid Background="#FFE5E5E5">
                    <ContentControl x:Name="SettingsFrame" Margin="167,10,10,10"/>
                    <TreeView Margin="10,10,0,10" HorizontalAlignment="Left" Width="152"
                              SelectedItemChanged="SettingsTree_SelectedItemChanged"
                              x:Name="SettingsTree">
                        <TreeViewItem Header="General" x:Name="GeneralSettingsItem" IsSelected="True"/>
                        <TreeViewItem Header="Server"/>
                        <TreeViewItem Header="Paths"/>
                    </TreeView>
                </Grid>
            </TabItem>
        </TabControl>

        <!-- 启动状态栏 (底部横条, 不遮挡内容) -->
        <Border x:Name="LoadingBar" Background="{DynamicResource MahApps.Brushes.Accent}"
                Height="32" VerticalAlignment="Bottom"
                Visibility="Visible">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" VerticalAlignment="Center">
                <mah:ProgressRing IsActive="True" Width="18" Height="18" Margin="0,0,8,0"/>
                <TextBlock x:Name="LoadingText" Text="Starting Alice Server..."
                           FontSize="12" Foreground="White" VerticalAlignment="Center"/>
            </StackPanel>
        </Border>

        <!-- 操作遮罩层 (Restart/Shutdown/Enable/Disable) -->
        <Grid x:Name="BusyOverlay" Background="#C0FFFFFF" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <mah:ProgressRing IsActive="True" Width="50" Height="50"/>
                <TextBlock x:Name="BusyText" Text="Working..."
                           FontSize="13" HorizontalAlignment="Center" Margin="0,12,0,0"
                           Foreground="#555"/>
            </StackPanel>
        </Grid>
    </Grid>
</mah:MetroWindow>
