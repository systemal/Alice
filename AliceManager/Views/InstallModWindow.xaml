<mah:MetroWindow x:Class="AliceManager.Views.InstallModWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:mah="clr-namespace:MahApps.Metro.Controls;assembly=MahApps.Metro"
        Title="Install Mod"
        Width="550" Height="280"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        TitleCharacterCasing="Normal"
        ShowIconOnTitleBar="False"
        BorderThickness="1"
        BorderBrush="{DynamicResource MahApps.Brushes.Accent}">

    <Grid Margin="16">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Tab 选择 -->
        <TabControl Grid.Row="0" x:Name="InstallTab" Height="140">
            <TabItem Header="GitHub">
                <StackPanel Margin="8,12">
                    <TextBlock Text="Repository URL:" Margin="0,0,0,6"/>
                    <TextBox x:Name="TxtGitUrl" Height="26"
                             mah:TextBoxHelper.Watermark="https://github.com/user/repo"/>
                </StackPanel>
            </TabItem>
            <TabItem Header="Local Folder">
                <StackPanel Margin="8,12">
                    <TextBlock Text="Source Directory:" Margin="0,0,0,6"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Browse..." Width="80" Height="26"
                                Margin="6,0,0,0" Click="BrowseFolder_Click"/>
                        <TextBox x:Name="TxtLocalPath" Height="26" IsReadOnly="True"/>
                    </DockPanel>
                </StackPanel>
            </TabItem>
            <TabItem Header="Pre-built File">
                <StackPanel Margin="8,12">
                    <TextBlock Text="DLL / Lua / JS File:" Margin="0,0,0,6"/>
                    <DockPanel>
                        <Button DockPanel.Dock="Right" Content="Browse..." Width="80" Height="26"
                                Margin="6,0,0,0" Click="BrowseFile_Click"/>
                        <TextBox x:Name="TxtFilePath" Height="26" IsReadOnly="True"/>
                    </DockPanel>
                    <TextBlock Text="Mod ID:" Margin="0,8,0,4"/>
                    <TextBox x:Name="TxtModId" Height="26"
                             mah:TextBoxHelper.Watermark="my-plugin"/>
                </StackPanel>
            </TabItem>
        </TabControl>

        <!-- 状态 -->
        <TextBlock Grid.Row="2" x:Name="TxtStatus" Text="Ready"
                   VerticalAlignment="Bottom" Margin="0,0,0,4"
                   Foreground="{DynamicResource MahApps.Brushes.Accent}"/>

        <!-- 按钮 -->
        <StackPanel Grid.Row="3" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="Cancel" Width="80" Height="28" Margin="0,0,8,0"
                    Click="Cancel_Click"/>
            <Button Content="Install" Width="80" Height="28"
                    Click="Install_Click" x:Name="BtnInstall"/>
        </StackPanel>
    </Grid>
</mah:MetroWindow>
